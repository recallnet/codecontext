#!/usr/bin/env sh
set -eu

echo "=== Pre-push checks ==="

# ── Check 1: No uncommitted changes ─────────────────────────────────
echo "[1/6] Checking for uncommitted changes..."
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "❌ Uncommitted changes detected. Commit or stash before pushing."
  exit 1
fi

# ── Check 2: Full build ─────────────────────────────────────────────
echo "[2/6] Building all packages..."
npx turbo build

# ── Check 3: Full lint ──────────────────────────────────────────────
echo "[3/6] Linting..."
npx turbo lint

# ── Check 4: Full type-check ────────────────────────────────────────
echo "[4/6] Type-checking..."
npx turbo typecheck

# ── Check 5: Full test suite ────────────────────────────────────────
echo "[5/6] Running all tests..."
npx turbo test

# ── Check 6: Go QA gates ────────────────────────────────────────────
echo "[6/7] Running Go QA gates..."
pnpm go:qa

# ── Check 7: Python QA gates ────────────────────────────────────────
echo "[7/7] Running Python QA gates..."
pnpm python:qa

echo "✅ All pre-push checks passed"
