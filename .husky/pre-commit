#!/usr/bin/env sh
set -eu

echo "=== Pre-commit checks ==="

GO_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^packages/golangci-lint/.*\.(go|mod|sum)$' || true)
PYTHON_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(packages/python/.*\.(py|toml)|examples/python/.*\.py)$' || true)
DOCS_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(docs/|\.remarkrc\.mjs$|AGENTS\.md$|package\.json$)' || true)
SKILLS_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(\.agents/skills/.*/SKILL\.md|scripts/validate-skills\.rb|package\.json$)' || true)

is_js_secret_scan_target() {
  case "$1" in
    *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs) return 0 ;;
    *) return 1 ;;
  esac
}

is_ts_console_scan_target() {
  case "$1" in
    *.test.*|*.spec.*) return 1 ;;
    *.ts|*.tsx) return 0 ;;
    *) return 1 ;;
  esac
}

# ── Stage 0: lint-staged (format staged files) ──────────────────────
echo "[0/10] Formatting staged files..."
npx lint-staged

# ── Stage 1: Lockfile sync ──────────────────────────────────────────
echo "[1/10] Checking lockfile sync..."
pnpm install --frozen-lockfile --ignore-scripts 2>/dev/null || {
  echo "❌ pnpm-lock.yaml is out of sync. Run 'pnpm install' and stage the lockfile."
  exit 1
}

# ── Stage 2: Type-check (affected packages) ─────────────────────────
echo "[2/10] Type-checking..."
npx turbo typecheck

# ── Stage 3: Lint (match CI scope) ──────────────────────────────────
echo "[3/10] Linting..."
pnpm lint

# ── Stage 4: Build ──────────────────────────────────────────────────
echo "[4/10] Building..."
npx turbo build

# ── Stage 5: Tests ──────────────────────────────────────────────────
echo "[5/10] Running tests..."
npx turbo test

# ── Stage 6: Go formatting/test gates ───────────────────────────────
if [ -n "$GO_CHANGED" ]; then
  echo "[6/10] Running Go QA gates..."
  pnpm go:fmt:check
  pnpm go:test
else
  echo "[6/10] Skipping Go QA gates (no Go changes)"
fi

# ── Stage 7: Python QA gates ────────────────────────────────────────
if [ -n "$PYTHON_CHANGED" ]; then
  echo "[7/11] Running Python QA gates..."
  pnpm python:qa
else
  echo "[7/11] Skipping Python QA gates (no Python changes)"
fi

# ── Stage 7b: Docs governance ───────────────────────────────────────
if [ -n "$DOCS_CHANGED" ]; then
  echo "[7b/11] Running docs governance..."
  pnpm docs:lint
else
  echo "[7b/11] Skipping docs governance (no docs changes)"
fi

# ── Stage 7c: Skills validation ─────────────────────────────────────
if [ -n "$SKILLS_CHANGED" ]; then
  echo "[7c/11] Validating skills..."
  pnpm skills:lint
else
  echo "[7c/11] Skipping skills validation (no skill changes)"
fi

# ── Stage 8: Hardcoded secrets check ────────────────────────────────
echo "[8/11] Checking for hardcoded secrets..."
SECRETS_REPORT=$(
  git diff --cached --name-only --diff-filter=d | while IFS= read -r file; do
    if is_js_secret_scan_target "$file"; then
      if git show ":$file" 2>/dev/null | grep -inE '(api[_-]?key|secret[_-]?key|password|token)\s*[:=]\s*["\x27][A-Za-z0-9+/=]{8,}' | grep -v '// eslint-disable' | grep -v 'process\.env' | grep -v 'import' >/dev/null 2>&1; then
        echo "⚠️  Possible hardcoded secret in: $file"
      fi
    fi
  done
)
if [ -n "$SECRETS_REPORT" ]; then
  printf '%s\n' "$SECRETS_REPORT"
  echo "❌ Potential secrets detected. Use environment variables instead."
  exit 1
fi

# ── Stage 9: Console.log warnings ───────────────────────────────────
echo "[9/11] Checking for console.log statements..."
CONSOLE_REPORT=$(
  git diff --cached --name-only --diff-filter=d | while IFS= read -r file; do
    if is_ts_console_scan_target "$file"; then
      if git show ":$file" 2>/dev/null | grep -n 'console\.log\b' >/dev/null 2>&1; then
        echo "⚠️  console.log found in: $file"
      fi
    fi
  done
)
if [ -n "$CONSOLE_REPORT" ]; then
  printf '%s\n' "$CONSOLE_REPORT"
  echo "⚠️  Warning: console.log statements found (non-blocking)"
fi

# ── Stage 10: Changeset requirement ─────────────────────────────────
# Check if any publishable package files changed without a changeset
CHANGED_PACKAGES=$(git diff --cached --name-only | grep -E '^packages/(parser|cli|eslint-plugin)/src/' || true)
if [ -n "$CHANGED_PACKAGES" ]; then
  CHANGESETS=$(git diff --cached --name-only | grep -E '^\.changeset/.*\.md$' || true)
  if [ -z "$CHANGESETS" ]; then
    echo "⚠️  Warning: Source files changed in publishable packages but no changeset found."
    echo "   Run 'pnpm changeset' to create one before merging to main."
  fi
fi

# ── Stage 11: Go module hygiene ─────────────────────────────────────
if [ -n "$GO_CHANGED" ]; then
  echo "[11/11] Verifying Go module metadata..."
  (cd packages/golangci-lint && go mod tidy)
  if ! git diff --quiet -- packages/golangci-lint/go.mod packages/golangci-lint/go.sum; then
    echo "❌ Go module files were out of date. Stage packages/golangci-lint/go.mod and go.sum."
    exit 1
  fi
else
  echo "[11/11] Skipping Go module hygiene (no Go changes)"
fi

echo "✅ All pre-commit checks passed"
