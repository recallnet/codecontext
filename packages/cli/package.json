{
  "name": "@recallnet/codecontext-cli",
  "version": "0.1.0",
  "private": false,
  "description": "CLI for querying @context annotations in source code",
  "repository": {
    "type": "git",
    "url": "https://github.com/recallnet/codecontext.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "bin": {
    "codecontext": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@recallnet/codecontext-parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
