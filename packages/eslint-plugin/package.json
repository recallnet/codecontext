{
  "name": "@recallnet/codecontext-eslint-plugin",
  "version": "0.2.2",
  "private": false,
  "description": "ESLint rules for @context annotation freshness and validity",
  "repository": {
    "type": "git",
    "url": "https://github.com/recallnet/codecontext.git",
    "directory": "packages/eslint-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/tsdoc": "^0.16.0",
    "@recallnet/codecontext-parser": "workspace:*"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
